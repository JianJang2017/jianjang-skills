# CDP / Chrome 远程调试地址（两个平台共用）
# 可选——连不上时脚本自动回落到 Playwright 自带 chromium + 持久化独立 profile
# （macOS: ~/.markdown-post-skill/chrome-profile；Windows: %USERPROFILE%\.markdown-post-skill\chrome-profile）。
# Chrome 136+ 安全限制不允许对主 profile 启用远程调试，所以默认就是走回落路径——
# 这里留空或保持默认值即可。
CDP_URL=http://localhost:9222

# 持久化 profile 目录（可选）——所有平台
# 默认 macOS: ~/.markdown-post-skill/chrome-profile
# 默认 Windows: %USERPROFILE%\.markdown-post-skill\chrome-profile
# 想换位置（如放到 SSD 临时盘）就显式设置：
# MARKDOWN_POST_PROFILE_DIR=

# 掘金默认分类（frontmatter 没写 category 时回落）
# 可选值（掘金一级分类，截至 2026 年中）：
#   后端 / 前端 / Android / iOS / 人工智能 / 开发工具 / 代码人生 / 阅读
JUEJIN_DEFAULT_CATEGORY=

# 飞帆默认分类（实际分类名以飞帆页面为准）
FEIFAN_DEFAULT_CATEGORY=

# 单步超时（毫秒）；网络差可调到 60000
JUEJIN_TIMEOUT_MS=30000
FEIFAN_TIMEOUT_MS=30000
