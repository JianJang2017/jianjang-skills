# 古诗词学习技能统一配置示例
# 包含微信公众号发布凭据 + 配图后端配置
#
# === 安装说明（macOS / Linux）===
# 1. 创建配置目录：
#    mkdir -p ~/.config/wechat-mp && chmod 700 ~/.config/wechat-mp
# 2. 复制并填写真实凭据：
#    cp wechat.env.profile.example ~/.config/wechat-mp/wechat.env.profile
# 3. 保护密钥文件：
#    chmod 600 ~/.config/wechat-mp/wechat.env.profile
#
# === 安装说明（Windows）===
# 1. 创建配置目录（PowerShell）：
#    New-Item -ItemType Directory -Force -Path "$env:USERPROFILE\.config\wechat-mp"
# 2. 复制并填写真实凭据：
#    copy wechat.env.profile.example "$env:USERPROFILE\.config\wechat-mp\wechat.env.profile"
# 3. 配置文件路径：
#    C:\Users\<你的用户名>\.config\wechat-mp\wechat.env.profile
#
# 取值优先级：命令行参数 > 配置文件 > 进程环境变量 > 内置默认值

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 微信公众号发布配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_APP_SECRET=0123456789abcdef0123456789abcdef

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 配图后端配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 默认配图后端：codex / gemini / qwen / auto（缺省 codex）
IMAGE_PROVIDER=codex

# 千问（阿里云百炼）API Key —— 仅当使用 qwen 后端时需要
# 获取地址：https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# 以下为千问可选项，通常保持默认即可
# QWEN_MODEL=qwen-image-2.0-pro
# QWEN_BASE_URL=https://dashscope.aliyuncs.com
# QWEN_NEGATIVE_PROMPT=低分辨率，低画质，画面具有AI感，文字模糊，扭曲

