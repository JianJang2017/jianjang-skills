{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "poem-meta.schema.json",
  "title": "Classical poetry verified metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "dynasty", "author", "lines", "verification"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "dynasty": {"type": "string", "minLength": 1},
    "author": {"type": "string", "minLength": 1},
    "lines": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "variant_notes": {"type": "array", "items": {"type": "string"}, "default": []},
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checked_at"],
      "properties": {
        "status": {"enum": ["verified", "partially_verified", "unverified"]},
        "sources": {"type": "array", "items": {"type": "string"}, "default": []},
        "checked_at": {"type": "string", "format": "date"},
        "notes": {"type": "string", "default": ""}
      }
    }
  }
}
