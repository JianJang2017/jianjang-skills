# 微信公众号发布凭证配置示例

# 在 ~/.config/wechat-mp/.env 创建此文件
# 或在项目根目录创建 .env 文件

# 微信公众号 AppID
WECHAT_APP_ID=wxabcd1234efgh5678

# 微信公众号 AppSecret
WECHAT_APP_SECRET=your_secret_key_here_32_characters

# 可选：默认作者
WECHAT_DEFAULT_AUTHOR=怀旧音乐

# 可选：是否默认打开评论 (0=关闭 1=打开)
WECHAT_OPEN_COMMENT=0

# 可选：是否仅粉丝可评论 (0=所有人 1=仅粉丝)
WECHAT_FANS_ONLY_COMMENT=0

# ==========================================
# 获取凭证步骤：
# ==========================================
# 1. 登录微信公众平台 (https://mp.weixin.qq.com)
# 2. 进入"设置与开发" -> "基本配置"
# 3. 查看"开发者ID(AppID)"
# 4. 点击"开发者密码(AppSecret)"旁的"重置"或"查看"
# 5. 将获取的 AppID 和 AppSecret 填入上方

# ==========================================
# 安全提示：
# ==========================================
# - 请勿将此文件提交到版本控制系统（已添加到 .gitignore）
# - AppSecret 仅显示一次，请妥善保管
# - 如 AppSecret 泄露，请立即重置
# - 定期更新 AppSecret 以提高安全性

# ==========================================
# 使用方式：
# ==========================================
# 方式 1：全局配置
#   mkdir -p ~/.config/wechat-mp
#   cp .env.example ~/.config/wechat-mp/.env
#   编辑 ~/.config/wechat-mp/.env 填入真实凭证
#
# 方式 2：项目配置
#   cp .env.example .env
#   编辑 .env 填入真实凭证
#
# 方式 3：环境变量
#   export WECHAT_APP_ID=wxabcd1234efgh5678
#   export WECHAT_APP_SECRET=your_secret_key
