# 接收用户的 open_id，多个用英文逗号分隔（ou_xxx,ou_yyy）
FEISHU_USER_IDS=ou_b8ad79eefb71ad5274c723d69219854e

# 接收群聊的 chat_id，多个用英文逗号分隔（oc_xxx,oc_yyy）
FEISHU_CHAT_IDS=oc_6f8ae483b7272f413a9ad01e6dbfec78,oc_d8145a9b52158a6577ab68a7fb538cc7,oc_fb4645b5742513c1761a132d0d7c8512

# 发送身份：bot（机器人，默认推荐）| user（用户本人，需 im:message.send_as_user 权限）
FEISHU_SEND_AS=bot
