# ───────────────────────────────────────────────
# 飞书推送配置（image-factory-skill）
# ───────────────────────────────────────────────
# 接收用户的 open_id，多个用英文逗号分隔（ou_xxx,ou_yyy）
FEISHU_USER_IDS=ou_b8ad7xxxxxxxxxxxxxx

# 接收群聊的 chat_id，多个用英文逗号分隔（oc_xxx,oc_yyy）
FEISHU_CHAT_IDS=oc_6f8aexxxxxxxxxxxxxx

# 发送身份：bot（机器人，默认推荐）| user（用户本人，需 im:message.send_as_user 权限）
FEISHU_SEND_AS=bot

# ───────────────────────────────────────────────
# 通义千问图像生成配置
# ───────────────────────────────────────────────
# 通义千问 API Key（必填）
# 获取方式：https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 业务空间 ID（Workspace ID，仅新加坡地域需要，国内可不填）
# 获取方式：https://help.aliyun.com/zh/model-studio/obtain-the-app-id-and-workspace-id
# 注意：国内地域（cn-beijing）使用统一端点，无需配置此项
DASHSCOPE_WORKSPACE_ID=

# 地域选择：cn-beijing（华北2北京，默认，推荐）| ap-southeast-1（新加坡）
# 注意：不同地域的 API Key 不可混用
# 国内用户推荐使用 cn-beijing，速度更快且无需 Workspace ID
DASHSCOPE_REGION=cn-beijing

# 模型选择（可选，默认 qwen-image-2.0-pro-2026-04-22）
# 可选值：
#   qwen-image-2.0-pro-2026-04-22  - Pro 系列最新版（推荐）
#   qwen-image-2.0-pro             - Pro 系列（指向最新版）
#   qwen-image-2.0                 - 加速版，效果与性能平衡
#   qwen-image-max                 - Max 系列，真实感与自然度更强
#   qwen-image-plus                - Plus 系列，多样化艺术风格与文字渲染
QWEN_IMAGE_MODEL=qwen-image-2.0-pro-2026-04-22

# 是否开启 Prompt 智能改写（可选，默认 true）
# true: 模型会优化提示词，让图像内容更多样化
# false: 严格按照原始提示词生成，细节更可控
QWEN_PROMPT_EXTEND=true

# 是否添加水印（可选，默认 false）
# true: 在图像右下角添加 "Qwen-Image" 水印
QWEN_WATERMARK=false

# 默认图片数量（可选，默认 1，qwen-image-2.0 系列支持 1-6 张）
QWEN_IMAGE_COUNT=1



# ───────────────────────────────────────────────
# 百炼 CLI (bl) 图像生成配置
# ───────────────────────────────────────────────
# 百炼 API Key（可选，优先使用 bl auth login 保存的凭证）
# 获取方式：https://bailian.console.aliyun.com/cn-beijing/?tab=app#/api-key
BL_API_KEY=

# 百炼 API Base URL（可选，默认使用 bl 配置的 base-url）
BL_BASE_URL=

# 模型选择（可选，默认 qwen-image-2.0-pro-2026-04-22，免费）
# 可登录查看https://bailian.console.aliyun.com/cn-beijing?spm=5176.29597918.J_F4r-7Zs_PtjrjEY48APSA.1.7b19133c7ckSzx&tab=costing-balance#/costing-balance/free-quota?modelType=Vision
# 可选值：
#   qwen-image-2.0-pro-2026-04-22 - Qwen-Image 2.0 Pro 最新版（免费，推荐）
#   qwen-image-2.0-pro          - Qwen-Image 2.0 Pro 版（更高质量）
#   qwen-image-2.0              - Qwen-Image 2.0 标准版（付费）
#   wan2.6-t2i                  - 通义万相 2.6 文生图
#   wan2.6-portrait             - 通义万相 2.6 人像
#   wan2.6-product              - 通义万相 2.6 商品
BL_IMAGE_MODEL=qwen-image-2.0-pro-2026-04-22

# 是否开启 Prompt 智能改写（可选，默认 true）
# true: 模型会优化提示词，让图像内容更多样化
# false: 严格按照原始提示词生成，细节更可控
BL_PROMPT_EXTEND=true

# 是否添加水印（可选，默认 false）
# true: 在图像上添加水印
# false: 不添加水印
BL_WATERMARK=false

# 默认图片数量（可选，默认 1，支持 1-6 张）
BL_IMAGE_COUNT=1